{
  "name": "@bounded-systems/policy",
  "version": "0.2.0",
  "description": "Tool-policy engine enforcing subcommand allowlists by tool, state, and role",
  "bounded": {
    "tagline": "Tool-policy engine enforcing subcommand allowlists by tool, state, and role",
    "kind": "room"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/policy.git"
  },
  "homepage": "https://github.com/bounded-systems/policy#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/policy/issues"
  },
  "keywords": [
